{
  "format": "custom",
  "id": "blog",
  "label": "Blog",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "Blog Slug"
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Blog Title",
          "placeholder": "How Himalayan Salt Lamps Improve Your Home Ambience"
        }
      },
      "excerpt": {
        "type": "Text",
        "config": {
          "label": "Excerpt",
          "placeholder": "Short summary shown on blog cards and search results."
        }
      },
      "body": {
        "type": "StructuredText",
        "config": {
          "label": "Blog Body",
          "placeholder": "",
          "allowTargetBlank": true,
          "multi": "heading1,heading2,heading3,strong,em,hyperlink,list-item,o-list-item,paragraph,preformatted"
        }
      },
      "featured_image": {
        "type": "Image",
        "config": {
          "label": "Featured Image",
          "constraint": {},
          "thumbnails": []
        }
      },
      "author_name": {
        "type": "Text",
        "config": {
          "label": "Author Name",
          "placeholder": "Saltros Editorial Team"
        }
      },
      "published_at": {
        "type": "Date",
        "config": {
          "label": "Published Date",
          "placeholder": ""
        }
      }
    },
    "SEO": {
      "seo_title": {
        "type": "Text",
        "config": {
          "label": "SEO Title",
          "placeholder": "Optional: defaults to Blog Title if empty"
        }
      },
      "seo_description": {
        "type": "Text",
        "config": {
          "label": "SEO Description",
          "placeholder": "Optional: defaults to Excerpt/body snippet if empty"
        }
      },
      "seo_image": {
        "type": "Image",
        "config": {
          "label": "SEO Image",
          "constraint": {},
          "thumbnails": []
        }
      },
      "canonical_url": {
        "type": "Text",
        "config": {
          "label": "Canonical URL",
          "placeholder": "https://www.example.com/blog/your-slug"
        }
      },
      "noindex": {
        "type": "Boolean",
        "config": {
          "label": "Noindex",
          "default_value": false,
          "false_label": "Index",
          "true_label": "Noindex"
        }
      }
    }
  }
}
